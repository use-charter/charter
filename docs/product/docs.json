              "rules/AE-SUPPRESS-001",
              "rules/AE-SUPPRESS-002",
              "rules/AE-SUPPRESS-003"
            ]
          }
        ]
      },
      {
        "tab": "Changelog",
        "groups": [
          {
            "group": "Updates",
            "icon": "history",
            "pages": ["changelog"]
          }
        ]
      }
    ]
  }
}
