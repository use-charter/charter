# Cloudflare Pages headers — https://developers.cloudflare.com/pages/configuration/headers/
# Security headers apply to every response; long-lived immutable caching for
# fingerprinted assets and self-hosted fonts.
#
# CSP: fetch directives lock to 'self' except the Cloudflare Web Analytics
# beacon — its loader script (static.cloudflareinsights.com) and its reporting
# endpoint (cloudflareinsights.com) are the only third-party origins allowed.
# script-src/style-src keep 'unsafe-inline' deliberately — a static host has no
# per-request nonce, and the page relies on inline scripts plus inline styles
# (syntax-highlight token colours and CSSOM-driven animations) that a hash-based
# policy cannot cover. frame-ancestors + X-Frame-Options both block framing.

/*
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; img-src 'self' data:; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' https://static.cloudflareinsights.com; connect-src 'self' https://cloudflareinsights.com; manifest-src 'self'; upgrade-insecure-requests
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), browsing-topics=()

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable
