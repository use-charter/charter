# Cloudflare Pages headers — https://developers.cloudflare.com/pages/configuration/headers/
# Security headers apply to every response; long-lived immutable caching for
# fingerprinted assets and self-hosted fonts.
#
# CSP: fetch directives lock to 'self' except the Cloudflare Web Analytics
# beacon — its loader script (static.cloudflareinsights.com) and its reporting
# endpoint (cloudflareinsights.com) are the only third-party origins allowed.
# script-src carries the SHA-256 hashes of the two inline scripts in Base.astro
# (theme-resolve and scroll-reveal) rather than 'unsafe-inline', so no injected
# inline script can execute. The csp-hashes test recomputes these from source and
# fails if Base.astro's inline scripts change without the hashes being updated.
# style-src keeps 'unsafe-inline': the page writes inline style attributes at
# runtime (CSSOM-driven meter/bar animations) whose values cannot be hashed.
# frame-ancestors + X-Frame-Options both block framing.

/*
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; img-src 'self' data:; font-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' https://static.cloudflareinsights.com 'sha256-rZisSQ/ZcPiTX2W3iDvFLT7TMc33sWX9SmhlkElvfmU=' 'sha256-mqNBdSL5tSg0ZPd/fZ/QrQ1ncWy+cTMKMEcfp0o8Xzw='; connect-src 'self' https://cloudflareinsights.com; manifest-src 'self'; upgrade-insecure-requests
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  Cross-Origin-Opener-Policy: same-origin
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), browsing-topics=()

/_astro/*
  Cache-Control: public, max-age=31536000, immutable

/fonts/*
  Cache-Control: public, max-age=31536000, immutable
