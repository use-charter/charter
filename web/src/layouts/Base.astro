---
import '../styles/global.css';

const SITE = 'https://use-charter.dev';
const TITLE = 'Charter — AI-agent readiness, scored.';
const DESCRIPTION =
  'Charter is an offline-first CLI that audits any repo against 18 rules and returns a deterministic 0–100 score in under 2 seconds.';
const OG_IMAGE = `${SITE}/og.png`;
const REPO = 'https://github.com/use-charter/charter';

// Per-page overrides; defaults render the home page unchanged.
interface Props {
  title?: string;
  description?: string;
  path?: string;
  bodyClass?: string;
  htmlClass?: string;
  ogType?: string;
  ogImage?: string;
}
const { title = TITLE, description = DESCRIPTION, path = '/', bodyClass = '', htmlClass = '', ogType = 'website', ogImage } = Astro.props;
// Allow per-page social images; resolve a relative path to an absolute URL.
const ogImageUrl = ogImage ? new URL(ogImage, SITE).href : OG_IMAGE;
const canonical = `${SITE}${path}`;

// schema.org graph — read by search engines (rich results) and AI answer
// engines to understand and cite the product. SoftwareApplication is the
// primary entity; WebSite and Organization give it context.
const STRUCTURED_DATA = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'WebSite',
      '@id': `${SITE}/#website`,
      url: `${SITE}/`,
      name: 'Charter',
      description: DESCRIPTION,
      inLanguage: 'en',
      publisher: { '@id': `${SITE}/#organization` },
    },
    {
      '@type': 'Organization',
      '@id': `${SITE}/#organization`,
      name: 'Charter',
      url: `${SITE}/`,
      logo: `${SITE}/icon-512.png`,
      sameAs: [REPO],
    },
    {
      '@type': 'SoftwareApplication',
      '@id': `${SITE}/#software`,
      name: 'Charter',
      description: DESCRIPTION,
      url: `${SITE}/`,
      applicationCategory: 'DeveloperApplication',
      operatingSystem: 'macOS, Linux, Windows',
      softwareVersion: '1.0.0',
      license: 'https://www.apache.org/licenses/LICENSE-2.0',
      codeRepository: REPO,
      downloadUrl: REPO,
      softwareHelp: { '@type': 'CreativeWork', url: `${SITE}/docs` },
      releaseNotes: `${SITE}/changelog`,
      featureList: '18 readiness rules across 9 categories; deterministic offline 0–100 scoring; diff-first auto-fix; SARIF 2.1.0 output; GitHub Action CI gate.',
      isAccessibleForFree: true,
      offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
      author: { '@id': `${SITE}/#organization` },
    },
  ],
};
---
<!doctype html>
<html lang="en" data-theme="dark" data-theme-mode="system" class={htmlClass}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <script is:inline>
    // Resolve the chosen theme mode pre-paint to avoid a flash. Default is
    // `system` → follow the OS; `light`/`dark` force the theme. The chosen
    // mode is mirrored on data-theme-mode so the switcher can restore its
    // active segment on load; data-theme always holds the resolved value.
    try {
      var mode = localStorage.getItem('charter-theme');
      if (mode !== 'light' && mode !== 'dark' && mode !== 'system') mode = 'system';
      var resolved = mode === 'system'
        ? (matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light')
        : mode;
      var root = document.documentElement;
      root.setAttribute('data-theme', resolved);
      root.setAttribute('data-theme-mode', mode);
    } catch(e) {}
    try { if (!matchMedia('(prefers-reduced-motion: reduce)').matches) { document.documentElement.classList.add('reveals-armed'); } } catch(e) {}
  </script>
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />
  <meta name="color-scheme" content="dark light" />
  <meta name="theme-color" content="#0d1117" media="(prefers-color-scheme: dark)" />
  <meta name="theme-color" content="#ffffff" media="(prefers-color-scheme: light)" />

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:site_name" content="Charter" />
  <meta property="og:locale" content="en_US" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:secure_url" content={ogImageUrl} />
  <meta property="og:image:type" content="image/png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="Charter — AI-agent readiness, scored." />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="@usecharter" />
  <meta name="twitter:creator" content="@usecharter" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImageUrl} />
  <meta name="twitter:image:alt" content="Charter — AI-agent readiness, scored." />

  <link rel="canonical" href={canonical} />
  <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />
  <link rel="preload" href="/fonts/ruda-400-800.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/atkinson-hyperlegible-mono-400-700.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.svg" />
  <link rel="manifest" href="/manifest.json" />
  <script type="application/ld+json" set:html={JSON.stringify(STRUCTURED_DATA)} is:inline></script>
  <!-- Per-page head extras (e.g. blog post Article schema + article:published_time) -->
  <slot name="head" />
</head>
<body class={bodyClass}>
  <div class="ck-page">
    <slot />
  </div>
  <div class="ck-grain" aria-hidden="true"></div>
  <script is:inline>
    // Scroll reveal — rAF animate --rv 0→1.4 per [data-reveal] section
    if (document.documentElement.classList.contains('reveals-armed')) {
      var secs = Array.from(document.querySelectorAll('[data-reveal]'));
      secs.forEach(function(s) { s.style.setProperty('--rv', '0'); });
      var animating = new Set();
      function runReveal(s) {
        if (animating.has(s) || s.dataset.revealed) return;
        animating.add(s);
        var start;
        var dur = 760;
        var tick = function(ts) {
          if (!start) start = ts;
          var p = Math.min(1, (ts - start) / dur);
          s.style.setProperty('--rv', ((1 - Math.pow(1 - p, 3)) * 1.4).toFixed(3));
          if (p < 1) requestAnimationFrame(tick);
          else { s.dataset.revealed = '1'; animating.delete(s); }
        };
        requestAnimationFrame(tick);
      }
      var raf = 0;
      function checkReveal() {
        var vh = window.innerHeight;
        var rem = 0;
        secs.forEach(function(s) {
          if (s.dataset.revealed) return;
          var r = s.getBoundingClientRect();
          if (r.top < vh * 0.86 && r.bottom > 0) runReveal(s);
          else rem++;
        });
        return rem;
      }
      function onScroll() {
        if (raf) return;
        raf = requestAnimationFrame(function() { raf = 0; if (checkReveal() === 0) detach(); });
      }
      function detach() {
        window.removeEventListener('scroll', onScroll);
        window.removeEventListener('resize', onScroll);
      }
      checkReveal();
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll);
      setTimeout(function() {
        secs.forEach(function(s) {
          if (!s.dataset.revealed) { s.style.setProperty('--rv', '1.4'); s.dataset.revealed = '1'; }
        });
        detach();
      }, 5000);
    }
  </script>
</body>
</html>
