---
import { Icon } from 'astro-icon/components';
import Nav from '../components/Nav.astro';
import FooterSection from '../components/FooterSection.astro';
import '../styles/legal.css';
import Base from './Base.astro';

interface Highlight {
  icon: string;
  label: string;
}
interface TocEntry {
  id: string;
  label: string;
}
interface Props {
  title: string;
  description: string;
  path: string;
  updated: string;
  summary: string;
  highlights?: Highlight[];
  toc?: TocEntry[];
}
const { title, description, path, updated, summary, highlights = [], toc = [] } = Astro.props;
---

<Base title={`${title} — Charter`} description={description} path={path}>
  <Nav />
  <div class="lp-progress" id="lp-progress" aria-hidden="true"></div>

  <main class="lp">
    <header class="lp-hero">
      <span class="lp-eyebrow">Legal</span>
      <h1 class="lp-title">{title}</h1>
      <p class="lp-meta"><span class="lp-meta__dot" aria-hidden="true"></span>Last updated {updated}</p>
      <p class="lp-summary">{summary}</p>

      {highlights.length > 0 && (
        <div class="lp-glance">
          {highlights.map((h) => (
            <div class="lp-glance__item">
              <span class="lp-glance__icon"><Icon name={`ph:${h.icon}`} /></span>
              <span class="lp-glance__label">{h.label}</span>
            </div>
          ))}
        </div>
      )}
    </header>

    <div class="lp-layout">
      <nav class="lp-toc" aria-label="On this page">
        <p class="lp-toc__title">On this page</p>
        <div class="lp-toc__list">
          {toc.map((t) => (
            <a class="lp-toc__link" href={`#${t.id}`} data-toc={t.id}>{t.label}</a>
          ))}
        </div>
      </nav>

      <article class="lp-content"><slot /></article>
    </div>
  </main>

  <FooterSection />

  <script is:inline>
    (function () {
      // Reading-progress bar: fraction of the document scrolled.
      var bar = document.getElementById('lp-progress');
      var onScroll = function () {
        var h = document.documentElement;
        var max = h.scrollHeight - h.clientHeight;
        var p = max > 0 ? Math.min(1, h.scrollTop / max) : 0;
        if (bar) bar.style.setProperty('--read', String(p));
      };
      onScroll();
      window.addEventListener('scroll', onScroll, { passive: true });

      // Scroll-spy: highlight the contents link for the section in view.
      var links = {};
      document.querySelectorAll('.lp-toc__link').forEach(function (a) {
        links[a.getAttribute('data-toc')] = a;
      });
      var sections = Array.from(document.querySelectorAll('.lp-section'));
      if ('IntersectionObserver' in window && sections.length) {
        var io = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (e) {
              if (e.isIntersecting) {
                Object.keys(links).forEach(function (k) { links[k].classList.remove('is-active'); });
                var active = links[e.target.id];
                if (active) active.classList.add('is-active');
              }
            });
          },
          { rootMargin: '-20% 0px -70% 0px', threshold: 0 }
        );
        sections.forEach(function (s) { io.observe(s); });
      }
    })();
  </script>
</Base>
