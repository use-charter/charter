---
import Base from '../layouts/Base.astro';
import ThemeSwitch from '../components/ThemeSwitch.astro';
import '../styles/dashboard.css';

// Founder mission-control dashboard. Cloudflare-Access-gated; data from
// /dashboard/api/stats on charter-router. Inverted-pyramid hierarchy: a status
// KPI strip (Tier 1), a dominant traffic hero chart (Tier 2), then detail tiles
// (Tier 3) in a bento grid. No React; excluded from the sitemap.
const KPIS = [
  { key: 'stars', label: 'Stars', d: 'M12 2.5l2.9 5.9 6.6.9-4.8 4.6 1.1 6.5L12 18l-5.9 3 1.1-6.5L2.5 9.8l6.6-.9z' },
  { key: 'forks', label: 'Forks', d: 'M6 3a3 3 0 1 0 0 6 3 3 0 0 0 0-6zm12 0a3 3 0 1 0 0 6 3 3 0 0 0 0-6zM9 6h6M12 9v6m0 0a3 3 0 1 0 0 6 3 3 0 0 0 0-6z' },
  { key: 'watchers', label: 'Watchers', d: 'M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7zm10 3a3 3 0 1 0 0-6 3 3 0 0 0 0 6z' },
  { key: 'openIssues', label: 'Open issues', d: 'M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20zm0 5v6m0 4h.01' },
];
---

<Base title="Charter · Mission Control" path="/dashboard" htmlClass="mc-html" bodyClass="mc-body">
  <main class="mc" data-dash>
    <!-- top bar -->
    <header class="mc__top">
      <div class="mc__brand">
        <span class="mc__mark">
          <svg viewBox="0 0 64 64" fill="currentColor" aria-hidden="true">
            <rect x="3" y="12" width="4" height="40"/><rect x="3" y="12" width="11" height="4"/><rect x="3" y="48" width="11" height="4"/>
            <rect x="57" y="12" width="4" height="40"/><rect x="50" y="12" width="11" height="4"/><rect x="50" y="48" width="11" height="4"/>
            <path d="M41.53,26.5 A11,11 0 1 0 41.53,37.5" fill="none" stroke="currentColor" stroke-width="6"/>
          </svg>
        </span>
        <div>
          <h1>Mission Control</h1>
          <p class="mc__repo"><span data-repo>use-charter/charter</span></p>
        </div>
      </div>
      <div class="mc__tools">
        <span class="mc__live"><i class="mc__dot"></i><span data-stamp>connecting…</span></span>
        <span class="mc__win">14-day window</span>
        <button type="button" class="mc__btn" data-refresh aria-label="Refresh">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-3-6.7L21 8"/><path d="M21 3v5h-5"/></svg>
        </button>
        <ThemeSwitch />
      </div>
    </header>

    <div class="mc__banner" data-banner hidden></div>

    <!-- Tier 1 — status KPIs -->
    <section class="mc__kpis" aria-label="Headline metrics">
      {KPIS.map((k) => (
        <article class="kpi" data-kpi={k.key}>
          <span class="kpi__ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round"><path d={k.d}/></svg></span>
          <span class="kpi__value" data-v data-target="0">—</span>
          <span class="kpi__label">{k.label}</span>
        </article>
      ))}
    </section>

    <!-- Tier 2/3 — bento -->
    <div class="mc__bento">
      <!-- hero: traffic -->
      <article class="tile tile--hero">
        <div class="tile__head">
          <h2>Traffic</h2>
          <div class="tile__legend"><span class="lg lg--views">Views</span><span class="lg lg--clones">Clones</span></div>
        </div>
        <div class="hero__metric">
          <span class="hero__num" data-v data-target="0" data-hero="views">—</span>
          <span class="hero__unit">views · 14d</span>
          <span class="delta" data-delta="views"></span>
          <span class="hero__aux" data-hero="uniqueViews">— unique</span>
        </div>
        <div class="hero__chart"><svg viewBox="0 0 600 200" preserveAspectRatio="none" data-chart="traffic" role="img" aria-label="Views and clones over 14 days"></svg></div>
        <div class="hero__xaxis" data-xaxis></div>
      </article>

      <!-- releases -->
      <article class="tile tile--rel">
        <div class="tile__head"><h2>Releases &amp; installs</h2></div>
        <a class="rel__tag" data-rel-tag href="#">—</a>
        <span class="rel__date" data-rel-date></span>
        <div class="rel__big"><span class="rel__n" data-v data-target="0" data-hero="downloads">—</span><span>total downloads</span></div>
        <ul class="rel__assets" data-rel-assets></ul>
      </article>

      <!-- adoption -->
      <article class="tile tile--adopt">
        <div class="tile__head"><h2>Adoption &amp; signals</h2></div>
        <div class="adopt__row">
          <div class="adopt__stat"><span data-v data-target="0" data-hero="action">—</span><small>action repos</small></div>
          <div class="adopt__stat"><span data-v data-target="0" data-hero="schema">—</span><small>schema refs</small></div>
        </div>
        <p class="adopt__cap">Recent adopters</p>
        <ul class="adopt__list" data-adopters><li class="muted">—</li></ul>
        <a class="adopt__link" data-signals href="#" target="_blank" rel="noopener">launch-signals digest →</a>
      </article>

      <!-- community -->
      <article class="tile tile--comm">
        <div class="tile__head"><h2>Community</h2></div>
        <div class="comm__row">
          <div class="comm__donut">
            <svg viewBox="0 0 120 120" data-donut role="img" aria-label="Open vs closed issues"></svg>
            <div class="comm__center"><b data-donut-total>—</b><span>issues</span></div>
          </div>
          <dl class="comm__legend">
            <div><dt><i class="sw sw--open"></i>Open</dt><dd data-c="openIssues">—</dd></div>
            <div><dt><i class="sw sw--closed"></i>Closed</dt><dd data-c="closedIssues">—</dd></div>
            <div><dt><i class="sw sw--pr"></i>Open PRs</dt><dd data-c="openPRs">—</dd></div>
          </dl>
        </div>
      </article>
    </div>

    <footer class="mc__foot">
      <span>Cloudflare Access · founder-only</span>
      <a href="/">← use-charter.dev</a>
    </footer>
  </main>

  <script>
    import '../islands/dashboard';
  </script>
</Base>
