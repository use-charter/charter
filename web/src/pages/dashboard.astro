---
import Base from '../layouts/Base.astro';
import ThemeSwitch from '../components/ThemeSwitch.astro';
import '../styles/dashboard.css';

// Founder mission-control dashboard. Gated at the edge by Cloudflare Access
// (only the founder's identity); data comes from /dashboard/api/stats on the
// charter-router worker. Not linked anywhere and excluded from the sitemap.
const KPIS = [
  { key: 'stars', label: 'Stars', icon: 'star' },
  { key: 'forks', label: 'Forks', icon: 'fork' },
  { key: 'views', label: 'Views · 14d', icon: 'eye' },
  { key: 'clones', label: 'Clones · 14d', icon: 'download' },
];
---

<Base title="Charter · Mission Control" path="/dashboard" htmlClass="dash-html" bodyClass="dash-body">
  <main class="dash" data-dash>
    <header class="dash__bar">
      <div class="dash__brand">
        <svg class="dash__mark" viewBox="0 0 64 64" fill="currentColor" aria-hidden="true">
          <rect x="3" y="12" width="4" height="40"/><rect x="3" y="12" width="11" height="4"/><rect x="3" y="48" width="11" height="4"/>
          <rect x="57" y="12" width="4" height="40"/><rect x="50" y="12" width="11" height="4"/><rect x="50" y="48" width="11" height="4"/>
          <path d="M41.53,26.5 A11,11 0 1 0 41.53,37.5" fill="none" stroke="currentColor" stroke-width="6"/>
        </svg>
        <div>
          <h1>Mission Control</h1>
          <p class="dash__sub">Post-launch metrics · <span data-repo>use-charter/charter</span></p>
        </div>
      </div>
      <div class="dash__tools">
        <span class="dash__stamp" data-stamp>—</span>
        <button type="button" class="dash__refresh" data-refresh aria-label="Refresh">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12a9 9 0 1 1-3-6.7L21 8"/><path d="M21 3v5h-5"/></svg>
          <span>Refresh</span>
        </button>
        <ThemeSwitch />
      </div>
    </header>

    <!-- status banners (shown by state) -->
    <div class="dash__banner" data-banner hidden></div>

    <!-- KPI row -->
    <section class="dash__kpis" aria-label="Headline metrics">
      {KPIS.map((k) => (
        <article class="kpi" data-kpi={k.key}>
          <span class="kpi__label">{k.label}</span>
          <span class="kpi__value" data-v>—</span>
          <span class="kpi__sub" data-sub></span>
        </article>
      ))}
    </section>

    <div class="dash__grid">
      <!-- Growth & traffic -->
      <article class="card card--wide">
        <div class="card__head"><h2>Growth &amp; traffic</h2><span class="card__tag">14-day</span></div>
        <div class="card__charts">
          <figure class="spark"><figcaption>Views<b data-trend="views">—</b></figcaption><svg viewBox="0 0 300 64" preserveAspectRatio="none" data-spark="views"></svg></figure>
          <figure class="spark"><figcaption>Clones<b data-trend="clones">—</b></figcaption><svg viewBox="0 0 300 64" preserveAspectRatio="none" data-spark="clones"></svg></figure>
        </div>
        <dl class="card__stats">
          <div><dt>Watchers</dt><dd data-g="watchers">—</dd></div>
          <div><dt>Unique views</dt><dd data-g="uniqueViews">—</dd></div>
          <div><dt>Unique cloners</dt><dd data-g="uniqueClones">—</dd></div>
          <div><dt>Open issues</dt><dd data-g="openIssues">—</dd></div>
        </dl>
      </article>

      <!-- Releases & installs -->
      <article class="card">
        <div class="card__head"><h2>Releases &amp; installs</h2></div>
        <div class="rel" data-rel>
          <div class="rel__top"><a class="rel__tag" data-rel-tag href="#">—</a><span class="rel__date" data-rel-date></span></div>
          <div class="rel__dl"><span class="rel__dl-n" data-rel-downloads>—</span><span>total downloads</span></div>
          <ul class="rel__assets" data-rel-assets></ul>
        </div>
      </article>

      <!-- Adoption & signals -->
      <article class="card">
        <div class="card__head"><h2>Adoption &amp; signals</h2></div>
        <div class="adopt">
          <div class="adopt__nums">
            <div><span data-a="action">—</span><small>action repos</small></div>
            <div><span data-a="schema">—</span><small>schema refs</small></div>
          </div>
          <p class="adopt__cap">Recent adopters</p>
          <ul class="adopt__list" data-adopters><li class="muted">—</li></ul>
          <a class="adopt__link" data-signals href="#" target="_blank" rel="noopener">launch-signals digest →</a>
        </div>
      </article>

      <!-- Community -->
      <article class="card card--wide">
        <div class="card__head"><h2>Community</h2></div>
        <dl class="card__stats card__stats--3">
          <div><dt>Open issues</dt><dd data-c="openIssues">—</dd></div>
          <div><dt>Closed issues</dt><dd data-c="closedIssues">—</dd></div>
          <div><dt>Open PRs</dt><dd data-c="openPRs">—</dd></div>
        </dl>
      </article>
    </div>

    <footer class="dash__foot">
      <span>Gated by Cloudflare Access · founder-only</span>
      <a href="/">← use-charter.dev</a>
    </footer>
  </main>

  <script>
    import '../islands/dashboard';
  </script>
</Base>
