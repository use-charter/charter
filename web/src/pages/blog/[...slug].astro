---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import DocPage from '../../components/DocPage.astro';
import '../../styles/marketing.css';
import '../../styles/legal.css';
import '../../styles/blog.css';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
// H2s are the numbered sections (rail + doc badges); H3s stay inline in the prose.
const sections = headings.filter((h) => h.depth === 2);

const SITE = 'https://use-charter.dev';
const url = `${SITE}/blog/${post.id}`;
const fmtDate = (d: Date): string => d.toLocaleDateString('en', { year: 'numeric', month: 'long', day: 'numeric' });
const words = (post.body ?? '').split(/\s+/).filter(Boolean).length;
const readTime = Math.max(1, Math.round(words / 200));

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString(),
  dateModified: (post.data.updated ?? post.data.date).toISOString(),
  author: { '@type': 'Organization', name: post.data.author, url: SITE },
  publisher: { '@type': 'Organization', name: 'Charter', url: SITE, logo: `${SITE}/icon-512.png` },
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
  keywords: post.data.tags.join(', '),
};

const breadcrumbs = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${SITE}/blog` },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: url },
  ],
};
---

<Base title={`${post.data.title} · Charter`} description={post.data.description} path={`/blog/${post.id}`} ogType="article" ogImage={`/og/${post.id}.png`} htmlClass="ck-html" bodyClass="ck-body">
  <Fragment slot="head">
    <meta property="article:published_time" content={post.data.date.toISOString()} />
    {post.data.updated && <meta property="article:modified_time" content={post.data.updated.toISOString()} />}
    <meta property="article:author" content={post.data.author} />
    {post.data.tags.map((t) => <meta property="article:tag" content={t} />)}
    <link rel="alternate" type="application/rss+xml" title="Charter Blog" href="/blog/rss.xml" />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbs)} />
  </Fragment>

  <DocPage
    backHref="/blog"
    backLabel="all posts"
    kicker="the charter blog"
    command={{ text: 'charter read', flag: post.id, comment: `opening ${post.id}.md` }}
    title={post.data.title}
    meta={[fmtDate(post.data.date), `${readTime} min read`, `${words.toLocaleString()} words`, post.data.author]}
    lede={post.data.description}
    chips={post.data.tags.map((t) => ({ icon: 'ph:hash', t }))}
    chipsInline
    sections={sections.map((h) => ({ id: h.slug, title: h.text }))}
    fileName={`${post.id}.md`}
  >
    <div class="lg-doc__body bl-doc">
      <Content />
      <footer class="bl-doc__foot">
        <div class="lg-chips lg-chips--inline">{post.data.tags.map((t) => <div class="lg-chip">#{t}</div>)}</div>
        <a class="bl-doc__back" href="/blog">← all posts</a>
      </footer>
    </div>
  </DocPage>
</Base>
