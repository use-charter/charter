---
import { getCollection, render } from 'astro:content';
import { Icon } from 'astro-icon/components';
import Base from '../../layouts/Base.astro';
import SiteNav from '../../components/SiteNav.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import '../../styles/marketing.css';
import '../../styles/legal.css';
import '../../styles/blog.css';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
// H2s are the numbered sections (rail + doc badges); H3s stay inline in the prose.
const sections = headings.filter((h) => h.depth === 2);

const SITE = 'https://use-charter.dev';
const url = `${SITE}/blog/${post.id}`;
const fmtDate = (d: Date): string => d.toLocaleDateString('en', { year: 'numeric', month: 'long', day: 'numeric' });
const words = (post.body ?? '').split(/\s+/).filter(Boolean).length;
const readTime = Math.max(1, Math.round(words / 200));
const padNo = (i: number): string => String(i + 1).padStart(2, '0');

const schema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date.toISOString(),
  dateModified: (post.data.updated ?? post.data.date).toISOString(),
  author: { '@type': 'Organization', name: post.data.author, url: SITE },
  publisher: { '@type': 'Organization', name: 'Charter', url: SITE, logo: `${SITE}/icon-512.png` },
  mainEntityOfPage: { '@type': 'WebPage', '@id': url },
  keywords: post.data.tags.join(', '),
};

const breadcrumbs = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: SITE },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: `${SITE}/blog` },
    { '@type': 'ListItem', position: 3, name: post.data.title, item: url },
  ],
};
---

<Base title={`${post.data.title} · Charter`} description={post.data.description} path={`/blog/${post.id}`} ogType="article" ogImage={`/og/${post.id}.png`} htmlClass="ck-html" bodyClass="ck-body">
  <Fragment slot="head">
    <meta property="article:published_time" content={post.data.date.toISOString()} />
    {post.data.updated && <meta property="article:modified_time" content={post.data.updated.toISOString()} />}
    <meta property="article:author" content={post.data.author} />
    {post.data.tags.map((t) => <meta property="article:tag" content={t} />)}
    <link rel="alternate" type="application/rss+xml" title="Charter Blog" href="/blog/rss.xml" />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbs)} />
  </Fragment>

  <div class="ck">
    <SiteNav backHref="/blog" backLabel="all posts" />

    <main>
      <section class="lg-hero">
        <div class="lg-hero__kicker">the charter blog</div>
        <div class="lg-cmd">
          <span class="ch">❯ </span>charter read <span class="fl">{post.id}</span> <span class="out"># opening {post.id}.md</span>
        </div>
        <h1 class="lg-hero__title">{post.data.title}</h1>
        <div class="lg-meta">
          <span class="item"><span class="ping"></span>{fmtDate(post.data.date)}</span>
          <span class="sep">·</span><span class="item">{readTime} min read</span>
          <span class="sep">·</span><span class="item">{words.toLocaleString()} words</span>
          <span class="sep">·</span><span class="item">{post.data.author}</span>
        </div>
        <p class="lg-hero__lede">{post.data.description}</p>
        <div class="lg-chips lg-chips--inline">
          {post.data.tags.map((t) => <div class="lg-chip"><Icon name="ph:hash" />{t}</div>)}
        </div>
      </section>

      <div class="lg-main">
        <aside class="lg-rail">
          <div class="lg-rail__h">on this page</div>
          <div class="lg-rail__bar"><i style="width:0%"></i></div>
          <nav class="lg-rail__nav" aria-label="On this page">
            {sections.map((h, i) => (
              <a href={`#${h.slug}`} class={i === 0 ? 'is-active' : ''}>
                <span class="n">{padNo(i)}</span>{h.text}
              </a>
            ))}
          </nav>
        </aside>

        <div class="lg-doc">
          <div class="lg-doc__bar">
            <span class="lg-doc__dots"><i></i><i></i><i></i></span>
            <span class="lg-doc__file"><b>{post.id}.md</b> — charter</span>
            <span class="lg-doc__meta">{sections.length} {sections.length === 1 ? 'section' : 'sections'}</span>
          </div>
          <div class="lg-doc__body bl-doc">
            <Content />
            <footer class="bl-doc__foot">
              <div class="lg-chips lg-chips--inline">{post.data.tags.map((t) => <div class="lg-chip"><Icon name="ph:hash" />{t}</div>)}</div>
              <a class="bl-doc__back" href="/blog">← all posts</a>
            </footer>
          </div>
        </div>
      </div>
    </main>

    <SiteFooter />
  </div>

  <script>
    import '../../islands/legal';
  </script>
</Base>
