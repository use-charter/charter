---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import ThemeSwitch from '../../components/ThemeSwitch.astro';
import '../../styles/marketing.css';
import '../../styles/legal.css';
import '../../styles/blog.css';

const REPO = 'https://github.com/use-charter/charter';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
const [featured, ...rest] = posts;

const fmtDate = (d: Date): string => d.toLocaleDateString('en', { year: 'numeric', month: 'short', day: 'numeric' });
const readTime = (body: string | undefined): number => Math.max(1, Math.round((body ?? '').split(/\s+/).filter(Boolean).length / 200));

const SITE = 'https://use-charter.dev';
const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'Blog',
  '@id': `${SITE}/blog`,
  name: 'Charter Blog',
  description: 'Notes on AI-agent readiness, deterministic scoring, supply-chain safety, and building Charter.',
  url: `${SITE}/blog`,
  inLanguage: 'en',
  publisher: { '@type': 'Organization', name: 'Charter', url: SITE, logo: `${SITE}/icon-512.png` },
  blogPost: posts.map((p) => ({
    '@type': 'BlogPosting',
    headline: p.data.title,
    description: p.data.description,
    url: `${SITE}/blog/${p.id}`,
    datePublished: p.data.date.toISOString(),
    author: { '@type': 'Organization', name: p.data.author },
  })),
};
---

<Base title="Blog · Charter" description="Notes on AI-agent readiness, deterministic scoring, supply-chain safety, and building Charter." path="/blog" htmlClass="bl-html" bodyClass="bl-body">
  <Fragment slot="head">
    <link rel="alternate" type="application/rss+xml" title="Charter Blog" href="/blog/rss.xml" />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(blogSchema)} />
  </Fragment>

  <header class="ck-bar ck-bar--legal">
    <div class="ck-bar__in">
      <a href="/" class="ck-bar__brand">
        <svg class="ck-bar__mark" viewBox="0 0 64 64" fill="currentColor" aria-hidden="true">
          <rect x="3" y="12" width="4" height="40"/><rect x="3" y="12" width="11" height="4"/><rect x="3" y="48" width="11" height="4"/>
          <rect x="57" y="12" width="4" height="40"/><rect x="50" y="12" width="11" height="4"/><rect x="50" y="48" width="11" height="4"/>
          <path d="M41.53,26.5 A11,11 0 1 0 41.53,37.5" fill="none" stroke="currentColor" stroke-width="6"/>
        </svg><span class="ck-bar__word">charter</span>
      </a>
      <a href="/" class="ck-bar__back">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 12H5M11 18l-6-6 6-6"/></svg> back to home
      </a>
      <span class="ck-bar__spacer"></span>
      <div class="ck-bar__right">
        <a href="/blog/rss.xml" class="ck-bar__gh" aria-label="RSS feed">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 11a9 9 0 0 1 9 9"/><path d="M4 4a16 16 0 0 1 16 16"/><circle cx="5" cy="19" r="1"/></svg>
        </a>
        <ThemeSwitch />
        <a href={REPO} class="ck-bar__gh" rel="noopener noreferrer" target="_blank" aria-label="GitHub">
          <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16" aria-hidden="true"><path d="M12 .5C5.7.5.5 5.8.5 12.3c0 5.2 3.4 9.6 8 11.2.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.5-1.4-1.3-1.8-1.3-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.4-1.3-5.4-5.9 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2a11.4 11.4 0 0 1 6 0C17 4.6 18 4.9 18 4.9c.6 1.7.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.4 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.6-1.6 8-6 8-11.2C23.5 5.8 18.3.5 12 .5z"/></svg>
        </a>
      </div>
    </div>
  </header>

  <main class="bl">
    <div class="bl__masthead">
      <span class="bl__eyebrow">The Charter blog</span>
      <h1>Notes from the agent era</h1>
      <p>Readiness, deterministic scoring, supply-chain safety — and what we learn shipping Charter.</p>
    </div>

    {featured && (
      <a class="bl-feat" href={`/blog/${featured.id}`}>
        <div class="bl-feat__body">
          <div class="bl-feat__tags">{featured.data.tags.map((t) => <span class="bl-tag">{t}</span>)}</div>
          <h2>{featured.data.title}</h2>
          <p>{featured.data.description}</p>
          <div class="bl-meta">
            <span>{featured.data.author}</span><span class="bl-meta__dot">·</span>
            <time datetime={featured.data.date.toISOString()}>{fmtDate(featured.data.date)}</time><span class="bl-meta__dot">·</span>
            <span>{readTime(featured.body)} min read</span>
          </div>
        </div>
        <span class="bl-feat__cta">Read the post<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg></span>
      </a>
    )}

    {rest.length > 0 && (
      <div class="bl-grid">
        {rest.map((p) => (
          <a class="bl-card" href={`/blog/${p.id}`}>
            <div class="bl-card__tags">{p.data.tags.map((t) => <span class="bl-tag">{t}</span>)}</div>
            <h3>{p.data.title}</h3>
            <p>{p.data.description}</p>
            <div class="bl-meta">
              <time datetime={p.data.date.toISOString()}>{fmtDate(p.data.date)}</time><span class="bl-meta__dot">·</span>
              <span>{readTime(p.body)} min</span>
            </div>
          </a>
        ))}
      </div>
    )}

    {posts.length === 0 && <p class="bl__empty">No posts yet — first one's coming.</p>}
  </main>

  <footer class="bl-foot">
    <span>&copy; {new Date().getFullYear()} · Charter</span>
    <a href="/blog/rss.xml">RSS</a>
  </footer>

  <script>
    import { initThemeSwitch } from '../../islands/theme';
    initThemeSwitch();
  </script>
</Base>
