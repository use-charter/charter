---
import { Icon } from 'astro-icon/components';
import Legal from '../layouts/Legal.astro';

const updated = 'June 12, 2026';
const summary =
  'This policy explains what the Charter website collects and why. The Charter CLI itself is offline by design — it makes no network calls and sends us nothing.';
const highlights = [
  { icon: 'wifi-slash', label: 'CLI sends no telemetry' },
  { icon: 'cookie', label: 'No tracking cookies' },
  { icon: 'prohibit', label: 'Your data is never sold' },
  { icon: 'shield-check', label: 'Offline by design' },
];
const toc = [
  { id: 'scope', label: 'Scope' },
  { id: 'cli', label: 'The Charter CLI' },
  { id: 'collect', label: 'What the site collects' },
  { id: 'use', label: 'How we use it' },
  { id: 'cookies', label: 'Cookies' },
  { id: 'third-parties', label: 'Third parties' },
  { id: 'retention', label: 'Retention' },
  { id: 'rights', label: 'Your rights' },
  { id: 'children', label: "Children's privacy" },
  { id: 'transfers', label: 'International transfers' },
  { id: 'changes', label: 'Changes' },
  { id: 'contact', label: 'Contact' },
];
---

<Legal
  title="Privacy Policy"
  description="How the Charter website handles data. The Charter CLI is offline-first: no network calls, no telemetry, nothing leaves your machine."
  path="/privacy"
  updated={updated}
  summary={summary}
  highlights={highlights}
  toc={toc}
>
  <section class="lp-section" id="scope">
    <h2><span class="lp-num">01</span><a href="#scope">Scope</a></h2>
    <p>
      This Privacy Policy applies to the website at <code>use-charter.dev</code> (the
      &ldquo;Site&rdquo;) operated by the Charter project (&ldquo;we&rdquo;, &ldquo;us&rdquo;).
      It describes what information is collected when you visit the Site and how it is handled.
      It does <strong>not</strong> apply to your use of the Charter command-line tool, which is
      covered separately in the section below.
    </p>
  </section>

  <section class="lp-section" id="cli">
    <h2><span class="lp-num">02</span><a href="#cli">The Charter CLI</a></h2>
    <div class="lp-callout">
      <Icon name="ph:shield-check" />
      <p><strong>In short:</strong> the CLI is fully offline. It never phones home, so we never receive your code, findings, or scores.</p>
    </div>
    <p>
      The Charter command-line tool runs entirely on your machine. By design it makes
      <strong>no network requests</strong>, performs <strong>no LLM calls</strong>, and emits
      <strong>no telemetry or analytics</strong>. Your repositories, scan results, and scores
      never leave your environment and are never transmitted to us or any third party. We have
      no ability to observe how you use the CLI.
    </p>
  </section>

  <section class="lp-section" id="collect">
    <h2><span class="lp-num">03</span><a href="#collect">What the site collects</a></h2>
    <p>When you visit the Site, limited technical information is processed to serve and secure the pages:</p>
    <ul>
      <li><strong>Server and CDN logs.</strong> Our hosting provider records standard request metadata — IP address, user agent, requested URL, and timestamp — to deliver content, prevent abuse, and maintain security.</li>
      <li><strong>No account data.</strong> The Site has no login, no user accounts, and no forms that collect personal information.</li>
      <li><strong>No advertising or cross-site trackers.</strong> We do not embed advertising networks or third-party tracking pixels.</li>
    </ul>
  </section>

  <section class="lp-section" id="use">
    <h2><span class="lp-num">04</span><a href="#use">How we use it</a></h2>
    <p>Technical information is used only to:</p>
    <ul>
      <li>Deliver and render the Site;</li>
      <li>Protect against abuse, fraud, and security threats;</li>
      <li>Understand aggregate traffic patterns to improve the Site.</li>
    </ul>
    <p>We do not sell, rent, or trade your information, and we do not use it for advertising.</p>
  </section>

  <section class="lp-section" id="cookies">
    <h2><span class="lp-num">05</span><a href="#cookies">Cookies</a></h2>
    <div class="lp-callout">
      <Icon name="ph:cookie" />
      <p><strong>In short:</strong> the Site uses a single local preference (your light/dark theme). No tracking cookies.</p>
    </div>
    <p>
      The Site stores your theme preference in your browser&rsquo;s <code>localStorage</code> so the
      page renders in your chosen appearance. This value stays on your device and is never sent to a
      server. We do not set advertising or cross-site tracking cookies.
    </p>
  </section>

  <section class="lp-section" id="third-parties">
    <h2><span class="lp-num">06</span><a href="#third-parties">Third parties</a></h2>
    <p>The Site relies on a small number of service providers:</p>
    <ul>
      <li><strong>Hosting &amp; CDN.</strong> The Site is served by a static hosting and content-delivery provider that processes request logs as described above.</li>
      <li><strong>Source &amp; documentation.</strong> Links to our code, license, and documentation point to GitHub and our documentation host; their own privacy policies apply once you follow those links.</li>
    </ul>
  </section>

  <section class="lp-section" id="retention">
    <h2><span class="lp-num">07</span><a href="#retention">Retention</a></h2>
    <p>
      Technical logs are retained only as long as needed for security and operational purposes,
      then deleted or anonymized in line with our hosting provider&rsquo;s standard practices.
      Because the Site collects no personal accounts, there is no profile data to retain.
    </p>
  </section>

  <section class="lp-section" id="rights">
    <h2><span class="lp-num">08</span><a href="#rights">Your rights</a></h2>
    <p>
      Depending on where you live (for example under the GDPR or CCPA), you may have the right to
      access, correct, delete, or restrict processing of personal data relating to you, and to
      object to certain processing. Because the Site does not maintain user accounts or marketing
      profiles, the data we hold about an individual visitor is minimal. To exercise any right,
      contact us using the details below.
    </p>
  </section>

  <section class="lp-section" id="children">
    <h2><span class="lp-num">09</span><a href="#children">Children&rsquo;s privacy</a></h2>
    <p>
      The Site is a developer tool and is not directed to children under 13 (or the equivalent age
      in your jurisdiction). We do not knowingly collect personal information from children.
    </p>
  </section>

  <section class="lp-section" id="transfers">
    <h2><span class="lp-num">10</span><a href="#transfers">International transfers</a></h2>
    <p>
      Our hosting and CDN operate globally, so technical request data may be processed in countries
      other than your own. Providers are selected for their adherence to recognized data-protection
      safeguards.
    </p>
  </section>

  <section class="lp-section" id="changes">
    <h2><span class="lp-num">11</span><a href="#changes">Changes</a></h2>
    <p>
      We may update this policy as the Site evolves. Material changes will be reflected by the
      &ldquo;Last updated&rdquo; date at the top of this page. Continued use of the Site after an
      update constitutes acceptance of the revised policy.
    </p>
  </section>

  <section class="lp-section" id="contact">
    <h2><span class="lp-num">12</span><a href="#contact">Contact</a></h2>
    <p>
      Questions about this policy or your data? Reach us at
      <a href="mailto:privacy@use-charter.dev">privacy@use-charter.dev</a> or open an issue on our
      <a href="https://github.com/use-charter/charter" rel="noopener noreferrer">GitHub repository</a>.
    </p>
  </section>
</Legal>
