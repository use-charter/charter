---
import { Icon } from 'astro-icon/components';

const STEPS = [
  { n: '01', cmd: 'charter init',        title: 'Scaffold the baseline',     tag: 'baseline ready',   gate: false,
    out: "Creates the context files an agent needs — AGENTS.md, charter.yaml, .gitignore — only what's missing." },
  { n: '02', cmd: 'charter doctor',      title: 'Get your number',           score: 52, zone: 'warn', zlabel: 'Needs work', gate: false,
    out: 'A static scan in under 2s scores the repo across 9 categories. Most repos land in the 40–60 range.' },
  { n: '03', cmd: 'charter fix',         title: 'Repair, diff-first',        score: 84, zone: 'pass', zlabel: 'Ship-ready', delta: '+32', gate: false,
    out: 'Approve unified diffs for the four safe fixers. Secrets and dangerous commands are never auto-touched.' },
  { n: '04', cmd: 'charter suppress',    title: 'Govern the exceptions',     tag: '1 waived · 90d',   gate: false,
    out: 'Log an accepted risk with a reason, an owner and an expiry. An audit trail that re-surfaces — not a mute button.' },
  { n: '05', cmd: 'charter-action@v1',   title: 'Gate every PR',             tag: 'threshold ≥ 80',   gate: true,
    out: 'CI re-scores each pull request and blocks merges below threshold. Readiness stops drifting and only ratchets up.' },
];
---
<section class="ck-section ck-life" id="lifecycle" data-reveal>
  <div class="ck-head">
    <span class="label-caps">The adoption loop</span>
    <h2>From first scan to a gate that holds</h2>
    <p>Readiness isn't a one-time cleanup. Charter takes a repo from an honest baseline to ship-ready — then makes the score a wall every pull request has to clear.</p>
  </div>

  <div class="ck-life__track" id="lifecycle-track" data-steps={STEPS.length}>
    <div class="ck-life__rail" aria-hidden="true"><span class="ck-life__rail-fill" id="life-rail"></span></div>
    {STEPS.map((s, i) => (
      <div class={`ck-life__node${s.gate ? ' is-gate' : ''}`} data-life-node={i}>
        <span class={`ck-life__marker${s.zone === 'pass' || s.gate ? ' is-pass' : s.zone === 'warn' ? ' is-warn' : ''}`}>
          {s.gate
            ? <Icon name="ph:shield-check" />
            : <span class="ck-life__mn">{s.n}</span>}
        </span>
        <div class="ck-life__card">
          <code class="ck-life__cmd">{s.cmd}</code>
          <h3 class="ck-life__title">{s.title}</h3>
          {s.score != null && (
            <div class={`ck-life__score is-${s.zone}`}>
              <span class="ck-life__num" data-life-score={s.score}>0</span>
              <span class="ck-life__den">/100</span>
              <span class="ck-life__zone">{s.zlabel}</span>
              {s.delta && <span class="ck-life__delta">{s.delta}</span>}
            </div>
          )}
          {s.tag && <span class={`ck-life__tag${s.gate ? ' is-gate' : ''}`}>{s.tag}</span>}
          <p class="ck-life__out">{s.out}</p>
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  const track = document.getElementById('lifecycle-track');
  // Step count drives the grid columns; set from the data attribute so the
  // markup carries no inline style (keeps the CSP free of inline-style hashes).
  if (track?.dataset.steps) track.style.setProperty('--steps', track.dataset.steps);
  const nodes = Array.from(document.querySelectorAll('[data-life-node]'));
  const scoreEls = document.querySelectorAll('[data-life-score]');
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function runLifecycle() {
    if (reduce) {
      nodes.forEach(n => { (n as HTMLElement).style.opacity = '1'; (n as HTMLElement).style.transform = 'none'; });
      if (track) track.style.setProperty('--fill', '100%');
      scoreEls.forEach(el => { el.textContent = (el as HTMLElement).dataset.lifeScore ?? ''; });
      return;
    }
    let start: number | undefined;
    const dur = 1800;
    const raf = (ts: number) => {
      if (!start) start = ts;
      const p = Math.min(1, (ts - start) / dur);
      const eased = 1 - Math.pow(1 - p, 3);
      const fill = Math.round(eased * 100);
      if (track) track.style.setProperty('--fill', fill + '%');
      nodes.forEach((n, i) => {
        const np = Math.max(0, Math.min(1, (fill - i * 13) / 20));
        (n as HTMLElement).style.opacity = String(np);
        (n as HTMLElement).style.transform = `translateY(${(1 - np) * 10}px)`;
      });
      if (p < 1) requestAnimationFrame(raf);
    };
    requestAnimationFrame(raf);
    // Animate score counters
    scoreEls.forEach(el => {
      const target = parseInt((el as HTMLElement).dataset.lifeScore ?? '0');
      let v = 0, started = false;
      const tryStart = setInterval(() => {
        const fillVal = parseFloat(track?.style.getPropertyValue('--fill') ?? '0') / 100;
        if (fillVal > 0.3 && !started) {
          started = true;
          clearInterval(tryStart);
          const t = setInterval(() => {
            v += 3;
            el.textContent = String(Math.min(target, v));
            if (v >= target) clearInterval(t);
          }, 20);
        }
      }, 50);
    });
  }

  // Trigger when section enters viewport
  if (track) {
    const io = new IntersectionObserver(([entry]) => {
      if (entry.isIntersecting) { runLifecycle(); io.disconnect(); }
    }, { threshold: 0.2 });
    io.observe(track);
  }
</script>
