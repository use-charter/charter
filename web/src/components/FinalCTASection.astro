---
import CopyButton from './CopyButton.astro';
import WaitlistForm from './WaitlistForm.astro';
---
<section id="final-cta" aria-labelledby="final-cta-heading" class="section final-cta">
  <h2 id="final-cta-heading" class="section__title">Start in 30 seconds</h2>

  <div class="final-cta__install">
    <CopyButton />
  </div>

  <div class="final-cta__links">
    <a href="https://use-charter.dev/docs" rel="noopener noreferrer" class="final-cta__primary">
      Read the docs
    </a>
    <a href="https://github.com/use-charter/charter" rel="noopener noreferrer" class="final-cta__secondary">
      Star on GitHub
    </a>
  </div>

  <div class="final-cta__waitlist">
    <WaitlistForm />
  </div>
</section>
