---
const command = 'brew install use-charter/tap/charter';
---
<div class="copy-install" role="group" aria-label="Install command">
  <span class="copy-sigil" aria-hidden="true">$</span>
  <span class="copy-cmd">{command}</span>
  <button type="button" class="copy-btn-icon copy-btn" data-command={command} aria-label="Copy install command">
    <!-- Copy icon -->
    <svg class="copy-btn__icon-copy" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 256 256" aria-hidden="true">
      <path fill="currentColor" d="M216,32H88a8,8,0,0,0-8,8V80H40a8,8,0,0,0-8,8V216a8,8,0,0,0,8,8H168a8,8,0,0,0,8-8V176h40a8,8,0,0,0,8-8V40A8,8,0,0,0,216,32ZM160,208H48V96H160Zm48-48H176V88a8,8,0,0,0-8-8H96V48H208Z"/>
    </svg>
    <!-- Check icon (shown on copy) -->
    <svg class="copy-btn__icon-check" xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 256 256" aria-hidden="true">
      <path fill="currentColor" d="M229.66,77.66l-128,128a8,8,0,0,1-11.32,0l-56-56a8,8,0,0,1,11.32-11.32L96,188.69,218.34,66.34a8,8,0,0,1,11.32,11.32Z"/>
    </svg>
  </button>
</div>

<style>
  .copy-btn__icon-copy,
  .copy-btn__icon-check {
    display: block;
    position: absolute;
    transition: opacity 200ms ease, transform 200ms ease;
  }
  .copy-btn-icon { position: relative; }

  /* Default: copy visible, check hidden */
  .copy-btn__icon-copy  { opacity: 1; transform: scale(1); }
  .copy-btn__icon-check { opacity: 0; transform: scale(0.5); color: #3fb950; }

  /* Copied state: check visible, copy hidden */
  .copy-btn.is-copied .copy-btn__icon-copy  { opacity: 0; transform: scale(0.5); }
  .copy-btn.is-copied .copy-btn__icon-check { opacity: 1; transform: scale(1); }

  /* Button glow on copied */
  .copy-btn.is-copied {
    color: #3fb950;
    background: rgba(63, 185, 80, 0.12);
  }
</style>

<script>
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const b = btn as HTMLButtonElement;
      const cmd = b.dataset.command ?? '';
      try {
        await navigator.clipboard.writeText(cmd);
      } catch {
        const i = document.createElement('input');
        i.value = cmd;
        document.body.appendChild(i);
        i.select();
        document.execCommand('copy');
        document.body.removeChild(i);
      }
      b.classList.add('is-copied');
      b.setAttribute('aria-label', 'Copied!');
      setTimeout(() => {
        b.classList.remove('is-copied');
        b.setAttribute('aria-label', 'Copy install command');
      }, 2000);
    });
  });
</script>
