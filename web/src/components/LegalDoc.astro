---
import { Icon } from 'astro-icon/components';
import ThemeSwitch from './ThemeSwitch.astro';
import type { LegalPage } from '../lib/legal-content';

interface Props {
  page: LegalPage;
}
const { page } = Astro.props;
const year = new Date().getFullYear();

const REPO = 'https://github.com/use-charter/charter';
const DOCS = 'https://use-charter.dev/docs';

// Split a trailing `--flag` out of the command so it can be tinted apart
// from the verb, mirroring the prompt styling on the rest of the site.
const flagMatch = page.cmd.match(/--\S+/);
const cmdHead = page.cmd.replace(/--\S+/, '');
const cmdFlag = flagMatch ? flagMatch[0] : '';

const padNo = (i: number): string => String(i + 1).padStart(2, '0');

const FOOT_COLS = [
  {
    h: 'Developers',
    links: [
      ['Quickstart', `${DOCS}/quickstart`],
      ['CLI reference', `${DOCS}/cli/overview`],
      ['Rules overview', `${DOCS}/rules/overview`],
      ['GitHub Action', `${DOCS}/ci/github-action`],
    ],
  },
  {
    h: 'Resources',
    links: [
      ['Documentation', DOCS],
      ['Changelog', 'https://use-charter.dev/changelog'],
      ['Source', REPO],
      ['llms.txt', '/llms.txt'],
    ],
  },
  {
    h: 'Legal',
    links: [
      ['Privacy', '/legal/privacy'],
      ['Terms', '/legal/terms'],
      ['License', '/legal/license'],
    ],
  },
] as const;
---

<div class="ck">
  <header class="ck-bar ck-bar--legal">
    <div class="ck-bar__in">
      <a href="/" class="ck-bar__brand">
        <svg class="ck-bar__mark" viewBox="0 0 64 64" fill="currentColor" aria-hidden="true">
          <rect x="3" y="12" width="4" height="40" /><rect x="3" y="12" width="11" height="4" /><rect x="3" y="48" width="11" height="4" />
          <rect x="57" y="12" width="4" height="40" /><rect x="50" y="12" width="11" height="4" /><rect x="50" y="48" width="11" height="4" />
          <path d="M41.53,26.5 A11,11 0 1 0 41.53,37.5" fill="none" stroke="currentColor" stroke-width="6" />
        </svg><span class="ck-bar__word">charter</span>
      </a>
      <a href="/" class="ck-bar__back"><Icon name="ph:arrow-left" /> back to home</a>
      <span class="ck-bar__spacer"></span>
      <div class="ck-bar__right">
        <ThemeSwitch />
        <a href={REPO} class="ck-bar__gh" rel="noopener noreferrer" target="_blank" aria-label="GitHub">
          <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16" aria-hidden="true"><path d="M12 .5C5.7.5.5 5.8.5 12.3c0 5.2 3.4 9.6 8 11.2.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.5-1.4-1.3-1.8-1.3-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.4-1.3-5.4-5.9 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2a11.4 11.4 0 0 1 6 0C17 4.6 18 4.9 18 4.9c.6 1.7.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.4 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.6-1.6 8-6 8-11.2C23.5 5.8 18.3.5 12 .5z" /></svg>
        </a>
      </div>
    </div>
  </header>

  <main>
    <section class="lg-hero">
      <div class="lg-hero__kicker">legal</div>
      <div class="lg-cmd">
        <span class="ch">❯ </span>{cmdHead}<span class="fl">{cmdFlag}</span> <span class="out"># opening {page.file}</span>
      </div>
      <h1 class="lg-hero__title">{page.title}</h1>
      <div class="lg-meta">
        <span class="item"><span class="ping"></span>Last updated {page.updated}</span>
        <span class="sep">·</span><span class="item">{page.read}</span>
        <span class="sep">·</span><span class="item">{page.words}</span>
      </div>
      <p class="lg-hero__lede" set:html={page.lede} />
      <div class="lg-chips">
        {page.chips.map((c) => (
          <div class="lg-chip"><Icon name={`ph:${c.icon}`} />{c.t}</div>
        ))}
      </div>
    </section>

    <div class="lg-main">
      <aside class="lg-rail">
        <div class="lg-rail__h">on this page</div>
        <div class="lg-rail__bar"><i style="width:0%"></i></div>
        <nav class="lg-rail__nav" aria-label="On this page">
          {page.sections.map((s, i) => (
            <a href={`#${s.id}`} class={i === 0 ? 'is-active' : ''}>
              <span class="n">{padNo(i)}</span>{s.title}
            </a>
          ))}
        </nav>
      </aside>

      <div class="lg-doc">
        <div class="lg-doc__bar">
          <span class="lg-doc__dots"><i></i><i></i><i></i></span>
          <span class="lg-doc__file"><b>{page.file}</b> — charter</span>
          <span class="lg-doc__meta">{page.sections.length} sections</span>
        </div>
        {page.sections.map((s, i) => (
          <section class="lg-sec" id={s.id}>
            <div class="lg-sec__h">
              <span class="lg-sec__no">{padNo(i)}</span>
              <h2>{s.title}</h2>
            </div>
            <div class="lg-sec__body">
              {s.blocks.map((b) => {
                if (b.t === 'p') return <p class={b.legalese ? 'legalese' : ''} set:html={b.html} />;
                if (b.t === 'list')
                  return (
                    <ul class="lg-list">
                      {b.items.map((it) => <li set:html={it} />)}
                    </ul>
                  );
                if (b.t === 'tldr')
                  return (
                    <div class={`lg-tldr ${b.tone}`}>
                      <Icon name={`ph:${b.icon}`} />
                      <span><span class="lbl">in short: </span><span set:html={b.html} /></span>
                    </div>
                  );
                if (b.t === 'perms')
                  return (
                    <div class="lg-perms">
                      <div class="lg-perm lg-perm--allow">
                        <div class="lg-perm__h"><Icon name="ph:check-circle" />permissions</div>
                        <ul>{b.permissions.map((x) => <li><span class="g">✓</span>{x}</li>)}</ul>
                      </div>
                      <div class="lg-perm lg-perm--cond">
                        <div class="lg-perm__h"><Icon name="ph:info" />conditions</div>
                        <ul>{b.conditions.map((x) => <li><span class="g">›</span>{x}</li>)}</ul>
                      </div>
                      <div class="lg-perm lg-perm--deny">
                        <div class="lg-perm__h"><Icon name="ph:prohibit" />limitations</div>
                        <ul>{b.limitations.map((x) => <li><span class="g">✕</span>{x}</li>)}</ul>
                      </div>
                    </div>
                  );
                if (b.t === 'code')
                  return (
                    <div class="lg-codepane">
                      <div class="lg-codepane__bar"><Icon name="ph:scroll" /> {b.title}</div>
                      <div class="lg-codepane__body" set:html={b.body} />
                      <div class="lg-codepane__more">
                        <span>2.1 KB · plain text</span>
                        <a href="https://www.apache.org/licenses/LICENSE-2.0" rel="noopener noreferrer" target="_blank">view full license ↗</a>
                      </div>
                    </div>
                  );
                return null;
              })}
            </div>
          </section>
        ))}
      </div>
    </div>
  </main>

  <footer class="ck-man">
    <div class="ck-man__mark" aria-hidden="true">
      <span class="base">charter</span>
      <span class="glow">charter</span>
    </div>
    <div class="ck-man__in">
      <div class="ck-man__title">
        <span>CHARTER(1)</span>
        <span>General Commands Manual</span>
      </div>
      <div class="ck-man__grid">
        <div>
          <a href="/" class="ck-man__brand-logo">
            <svg width="20" height="20" viewBox="0 0 64 64" fill="currentColor" aria-hidden="true">
              <rect x="3" y="12" width="4" height="40" /><rect x="3" y="12" width="11" height="4" /><rect x="3" y="48" width="11" height="4" />
              <rect x="57" y="12" width="4" height="40" /><rect x="50" y="12" width="11" height="4" /><rect x="50" y="48" width="11" height="4" />
              <path d="M41.53,26.5 A11,11 0 1 0 41.53,37.5" fill="none" stroke="currentColor" stroke-width="6" />
            </svg> charter
          </a>
          <p class="ck-man__tagline">AI-agent readiness, scored. Offline, deterministic, and yours to keep.</p>
          <div class="ck-man__chips" role="list">
            <span class="ck-man__chip" role="listitem"><Icon name="ph:wifi-slash" />offline-first</span>
            <span class="ck-man__chip" role="listitem"><Icon name="ph:user-circle" />no account</span>
            <span class="ck-man__chip" role="listitem"><Icon name="ph:eye-slash" />no telemetry</span>
          </div>
          <div class="ck-man__social">
            <a href={REPO} rel="noopener noreferrer" target="_blank" aria-label="GitHub">
              <svg viewBox="0 0 24 24" fill="currentColor" width="16" height="16" aria-hidden="true"><path d="M12 .5C5.7.5.5 5.8.5 12.3c0 5.2 3.4 9.6 8 11.2.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.5-1.4-1.3-1.8-1.3-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.4-1.3-5.4-5.9 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2a11.4 11.4 0 0 1 6 0C17 4.6 18 4.9 18 4.9c.6 1.7.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.4 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.6-1.6 8-6 8-11.2C23.5 5.8 18.3.5 12 .5z" /></svg>
            </a>
            <a href={DOCS} rel="noopener noreferrer" target="_blank" aria-label="Documentation"><Icon name="ph:book-open" /></a>
          </div>
        </div>
        {FOOT_COLS.map((col) => (
          <div>
            <h3>{col.h}</h3>
            <ul>{col.links.map((l) => <li><a href={l[1]}>{l[0]}</a></li>)}</ul>
          </div>
        ))}
        <div class="ck-sub">
          <div class="ck-sub__bar">
            <span class="ck-sub__dots"><i></i><i></i><i></i></span>
            <span class="ck-sub__ttl">charter subscribe</span>
          </div>
          <form class="ck-sub__body" novalidate>
            <div class="ck-sub__cmd"><span class="ch">❯ </span>charter subscribe <span class="fl">--updates</span></div>
            <div class="ck-sub__note">New rules and releases, straight to your inbox. No noise.</div>
            <div class="ck-sub__row">
              <label class="ck-sub__field">
                <span class="pfx">@</span>
                <input class="ck-sub__input" type="email" placeholder="you@example.com" aria-label="Email address" spellcheck="false" autocomplete="email" />
              </label>
              <button class="ck-sub__btn" type="submit">notify me</button>
            </div>
            <div class="ck-sub__ok" aria-live="polite"></div>
          </form>
        </div>
      </div>
    </div>
    <div class="ck-man__exit">
      <span class="ck-man__exit-l">
        <span class="ck-man__copy">&copy; {year} · Charter</span>
        <span class="sep" aria-hidden="true">|</span>
        <span>Apache 2.0</span>
      </span>
      <span class="ck-man__exit-r">
        <span>v1.0.0</span>
        <span class="sep" aria-hidden="true">|</span>
        <span class="ck-man__built">Built with
          <a href="https://astro.build/" rel="noopener noreferrer" target="_blank" aria-label="Astro">
            <img src="/icons/astro-wordmark.svg" alt="Astro" width="53" height="14" loading="lazy" />
          </a>
        </span>
      </span>
    </div>
  </footer>
</div>

<script>
  import '../islands/legal';
</script>
