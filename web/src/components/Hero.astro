---
import { Icon } from 'astro-icon/components';
import CopyButton from './CopyButton.astro';
---
<section class="ck-hero">
  <div class="ck-hero__grid">
    <div class="ck-hero__copy">
      <div class="ck-eyebrow">
        <span class="label-caps">Scan</span><span class="dot"></span>
        <span class="label-caps">Score</span><span class="dot"></span>
        <span class="label-caps">Fix</span>
      </div>
      <h1>AI-agent<br />readiness, <span class="accent-blue">scored.</span></h1>
      <p class="ck-lede">Charter scans any repository and returns a 0–100 readiness score in under two seconds — 18 rules across nine categories. Completely offline.</p>
      <div class="ck-install">
        <CopyButton />
      </div>
      <div class="ck-hero__actions">
        <a href="https://use-charter.dev/docs/quickstart" rel="noopener noreferrer" class="ck-btn ck-btn--primary ck-btn--lg">
          <Icon name="ph:book-open" />Get started
        </a>
        <button class="ck-btn ck-btn--ghost ck-btn--lg" id="rerun-scan">
          <Icon name="ph:arrow-counter-clockwise" />Re-run scan
        </button>
      </div>
      <p class="ck-reassure">
        <Icon name="ph:lock" />
        No network. No LLM calls. No data leaves your machine.
      </p>
    </div>

    <div class="ck-hero__demo">
      <div class="ck-terminal" role="region" aria-label="charter doctor output">
        <div class="ck-terminal__chrome">
          <span class="ck-terminal__dot ck-terminal__dot--r"></span>
          <span class="ck-terminal__dot ck-terminal__dot--y"></span>
          <span class="ck-terminal__dot ck-terminal__dot--g"></span>
          <span class="ck-terminal__title">~/acme-api &mdash; charter doctor</span>
        </div>
        <div class="ck-terminal__body" id="terminal-output" aria-live="polite" aria-atomic="false"></div>
      </div>
      <div class="ck-report">
        <div class="ck-report__score" id="score-display">
          <span class="ck-score-num" id="score-num">0</span>
          <span class="ck-score-den">/100</span>
        </div>
        <div class="ck-report__bars">
          <div class="ck-sbar">
            <span class="ck-sbar__label">context</span>
            <div class="ck-sbar__track"><div class="ck-sbar__fill" id="bar-context"></div></div>
          </div>
          <div class="ck-sbar">
            <span class="ck-sbar__label">secrets</span>
            <div class="ck-sbar__track"><div class="ck-sbar__fill ck-sbar__fill--danger" id="bar-secrets"></div></div>
          </div>
          <div class="ck-sbar">
            <span class="ck-sbar__label">mcp safety</span>
            <div class="ck-sbar__track"><div class="ck-sbar__fill ck-sbar__fill--warn" id="bar-mcp"></div></div>
          </div>
          <div class="ck-sbar">
            <span class="ck-sbar__label">autonomy</span>
            <div class="ck-sbar__track"><div class="ck-sbar__fill" id="bar-autonomy"></div></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
// Starship-style prompt helper — segments rendered as colored chips
const SS = (dir='acme-api', branch='main', dirty=true, rt='v24.16.0') =>
  `<span class="ck-ss">`+
    `<span class="ck-ss__seg ck-ss__dir">${dir}</span>`+
    `<span class="ck-ss__seg ck-ss__git">${branch}${dirty?' <span class="ck-ss__dirty">!</span>':''}</span>`+
    `<span class="ck-ss__seg ck-ss__node">${rt}</span>`+
  `</span>`;

const LINES = [
  SS(),
  `<span class="ck-ss__char">❯</span> <span class="t-cmd">charter</span> <span class="t-sub">doctor</span> <span class="t-flag">--strict</span>`,
  '',
  `<span class="t-brand">[C] charter</span> <span class="t-dim">v1.0.0 · ~/acme-api</span>`,
  `<span class="t-div">────────────────────────────────────────</span>`,
  `<span class="t-dim">Checked 18 rules · 3 findings · 1 BLOCKER · 1 HIGH · 1 MEDIUM</span>`,
  '',
  `<span class="t-fail">✗ BLOCKER</span>  <span class="t-rule">AE-SEC-001</span>  <span class="t-dim">Secrets</span>`,
  `<span class="t-dim">  raw secret in an agent-visible file</span>`,
  `<span class="t-warn">⚠ HIGH</span>     <span class="t-rule">AE-MCP-001</span>  <span class="t-dim">MCP Safety</span>`,
  `<span class="t-warn">⚠ MEDIUM</span>   <span class="t-rule">AE-AUTO-001</span> <span class="t-dim">Autonomy</span>`,
  '',
  `<span class="t-div">────────────────────────────────────────</span>`,
  `Score <span class="t-pass">82</span><span class="t-dim">/100  ████████████████░░░░  </span><span class="t-pass">PASS ✓</span>`,
  `<span class="t-dim">      threshold 80 · 1.84s · offline</span>`,
];

const out = document.getElementById('terminal-output');
const scoreNum = document.getElementById('score-num');
const bars = {
  context: document.getElementById('bar-context') as HTMLElement | null,
  secrets: document.getElementById('bar-secrets') as HTMLElement | null,
  mcp: document.getElementById('bar-mcp') as HTMLElement | null,
  autonomy: document.getElementById('bar-autonomy') as HTMLElement | null,
};

function addLine(html: string) {
  const div = document.createElement('div');
  div.className = 'ck-terminal__line';
  div.innerHTML = html || ' ';
  out?.appendChild(div);
}

function addCursorLine() {
  addLine(`<span class="ck-ss__char">❯</span> <span class="ck-term-cursor"></span>`);
}

function animScore(to: number, delay: number) {
  setTimeout(() => {
    let v = 0;
    const t = setInterval(() => {
      v += 3;
      if (scoreNum) scoreNum.textContent = String(Math.min(to, v));
      if (v >= to) clearInterval(t);
    }, 20);
  }, delay);
}

function animBar(el: HTMLElement | null, pct: number, delay: number) {
  if (!el) return;
  setTimeout(() => {
    el.style.transition = 'width 600ms cubic-bezier(0.16,1,0.3,1)';
    el.style.width = pct + '%';
  }, delay);
}

function runAnimation() {
  if (out) out.innerHTML = '';
  if (scoreNum) scoreNum.textContent = '0';
  Object.values(bars).forEach(b => {
    if (b) { b.style.transition = 'none'; b.style.width = '0%'; }
  });

  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (reduce) {
    LINES.forEach(l => addLine(l));
    addCursorLine();
    if (scoreNum) scoreNum.textContent = '82';
    animBar(bars.context, 100, 0);
    animBar(bars.secrets, 39, 0);
    animBar(bars.mcp, 67, 0);
    animBar(bars.autonomy, 80, 0);
    return;
  }

  let i = 0;
  const timer = setInterval(() => {
    addLine(LINES[i]);
    i++;
    if (i >= LINES.length) {
      clearInterval(timer);
      addCursorLine();
      animScore(82, 100);
      animBar(bars.context, 100, 200);
      animBar(bars.secrets, 39, 350);
      animBar(bars.mcp, 67, 500);
      animBar(bars.autonomy, 80, 650);
    }
  }, 190);
}

runAnimation();
document.getElementById('rerun-scan')?.addEventListener('click', runAnimation);
</script>
