---
import { Code } from 'astro:components';
import { Icon } from 'astro-icon/components';

const WORKFLOW = `# .github/workflows/charter.yml
name: Charter
on:
  pull_request:
permissions:
  contents: read
  security-events: write
jobs:
  charter:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v6
      - uses: use-charter/charter-action@v1
        with:
          threshold: "80"
          verify: true`;
---
<section class="ck-section" id="gate" data-reveal>
  <div class="ck-gate">
    <div class="ck-gate__copy">
      <span class="label-caps">GitHub Action</span>
      <h2>Gate every PR on readiness</h2>
      <p class="ck-sub">The action downloads the signed binary, runs <code>charter doctor --format sarif</code>, and uploads to GitHub Code Scanning — so findings show up natively on the PR and merges below your threshold are blocked.</p>
      <div class="ck-terminal ck-code-wrap">
        <div class="ck-terminal__chrome">
          <span class="ck-terminal__dot ck-terminal__dot--r"></span>
          <span class="ck-terminal__dot ck-terminal__dot--y"></span>
          <span class="ck-terminal__dot ck-terminal__dot--g"></span>
          <span class="ck-terminal__title">.github/workflows/charter.yml</span>
        </div>
        <div class="ck-terminal__body ck-shiki-wrap">
          <Code
            code={WORKFLOW}
            lang="yaml"
            themes={{ light: 'github-light', dark: 'github-dark' }}
            defaultColor={false}
          />
        </div>
      </div>
    </div>
    <div class="ck-gate__pr">
      <div class="ck-pr">
        <div class="ck-pr__head">
          <Icon name="ph:git-pull-request" />
          <span class="ck-pr__title">Wire the agent task runner</span>
          <span class="ck-pr__num">#412</span>
        </div>
        <div class="ck-check">
          <Icon name="ph:check" />
          <span class="ck-check__name">build</span>
          <span class="ck-check__meta">passed</span>
        </div>
        <div class="ck-check">
          <Icon name="ph:check" />
          <span class="ck-check__name">test</span>
          <span class="ck-check__meta">passed</span>
        </div>
        <div class="ck-check ck-check--charter">
          <Icon name="ph:gauge" />
          <span class="ck-check__name">charter / readiness</span>
          <span class="ck-check__meta">82/100 · min 80</span>
          <span class="c-badge c-badge--pass">PASS ✓</span>
        </div>
        <div class="ck-pr__foot">
          <span class="c-badge c-badge--pass">All checks passed</span>
          <span class="ck-pr__merge">Ready to merge</span>
        </div>
      </div>
    </div>
  </div>
</section>
