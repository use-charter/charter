---
import { Icon } from 'astro-icon/components';

const year = new Date().getFullYear();
const REPO = 'https://github.com/use-charter/charter';
const DOCS = 'https://use-charter.dev/docs';

const columns = [
  {
    title: 'Developers',
    links: [
      { label: 'Quickstart', href: `${DOCS}/quickstart` },
      { label: 'CLI reference', href: `${DOCS}/cli/overview` },
      { label: 'Rules overview', href: `${DOCS}/rules/overview` },
      { label: 'GitHub Action', href: `${DOCS}/ci/github-action` },
    ],
  },
  {
    title: 'Resources',
    links: [
      { label: 'Documentation', href: DOCS },
      { label: 'Changelog', href: `${DOCS}/changelog` },
      { label: 'Source', href: REPO, external: true },
      { label: 'llms.txt', href: '/llms.txt' },
    ],
  },
  {
    title: 'Legal',
    links: [
      { label: 'Privacy', href: '/privacy' },
      { label: 'Terms', href: '/terms' },
      { label: 'License', href: `${REPO}/blob/main/LICENSE`, external: true },
    ],
  },
];
---
<footer class="ck-footer">
  <section class="ck-foot" id="ck-foot">
    <div class="ck-foot__wm" id="ck-foot-wm" aria-hidden="true">
      <span class="ck-foot__wm-base">charter</span>
      <span class="ck-foot__wm-glow">charter</span>
    </div>

    <div class="ck-foot__grid">
      <div class="ck-foot__brand">
        <a href="#top" class="ck-foot__logo" aria-label="Charter home">
          <svg width="22" height="22" viewBox="0 0 64 64" fill="currentColor" aria-hidden="true">
            <rect x="3" y="12" width="4" height="40"/><rect x="3" y="12" width="11" height="4"/><rect x="3" y="48" width="11" height="4"/>
            <rect x="57" y="12" width="4" height="40"/><rect x="50" y="12" width="11" height="4"/><rect x="50" y="48" width="11" height="4"/>
            <path d="M41.53,26.5 A11,11 0 1 0 41.53,37.5" fill="none" stroke="currentColor" stroke-width="6"/>
          </svg>
          <span>charter</span>
        </a>
        <p class="ck-foot__tagline">AI-agent readiness, scored. Offline, deterministic, and yours.</p>
        <span class="ck-foot__status"><span class="ck-foot__status-dot" aria-hidden="true"></span>Offline-first &middot; no telemetry</span>
        <div class="ck-foot__social">
          <a href={REPO} class="ck-foot__icon" rel="noopener noreferrer" target="_blank" aria-label="GitHub">
            <svg viewBox="0 0 24 24" fill="currentColor" width="17" height="17" aria-hidden="true"><path d="M12 .5C5.7.5.5 5.8.5 12.3c0 5.2 3.4 9.6 8 11.2.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.5-1.4-1.3-1.8-1.3-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.4-1.3-5.4-5.9 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2a11.4 11.4 0 0 1 6 0C17 4.6 18 4.9 18 4.9c.6 1.7.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.4 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.6-1.6 8-6 8-11.2C23.5 5.8 18.3.5 12 .5z"/></svg>
          </a>
          <a href={DOCS} class="ck-foot__icon" rel="noopener noreferrer" target="_blank" aria-label="Documentation">
            <Icon name="ph:book-open" />
          </a>
        </div>
      </div>

      <nav class="ck-foot__cols" aria-label="Footer">
        {columns.map((col) => (
          <div class="ck-foot__col">
            <p class="ck-foot__h">{col.title}</p>
            <ul>
              {col.links.map((l) => (
                <li>
                  <a
                    href={l.href}
                    {...(l.external ? { rel: 'noopener noreferrer', target: '_blank' } : {})}
                  >{l.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </nav>

      <aside class="ck-foot__cta">
        <p class="ck-foot__cta-eyebrow">Stay in the loop</p>
        <p class="ck-foot__cta-title">Get product updates.</p>
        <p class="ck-foot__cta-sub">New rules and releases, straight to your inbox. No noise.</p>
        <form id="waitlist-form" class="ck-foot__form" novalidate>
          <div class="ck-foot__form-row">
            <input
              id="waitlist-email"
              name="email"
              type="email"
              required
              autocomplete="email"
              placeholder="you@example.com"
              class="ck-foot__input"
              aria-label="Email address"
              aria-describedby="email-error"
            />
            <button type="submit" id="waitlist-submit" class="ck-btn ck-btn--primary ck-foot__submit">Notify me</button>
          </div>
          <span id="email-error" class="ck-foot__err" role="alert" aria-atomic="true"></span>
        </form>
      </aside>
    </div>

    <div class="ck-foot__bar">
      <span class="ck-foot__copy">&copy; {year} Charter &middot; Offline. Deterministic. Yours.</span>
      <span class="ck-foot__build">Apache-2.0 &middot; SLSA L3 &middot; v1.0.0</span>
    </div>
  </section>
</footer>

<script>
  import { initWaitlistForm } from '../islands/WaitlistForm';

  // Wire the product-updates form (validation, submit, toast).
  initWaitlistForm();

  // Oversized wordmark: a glow layer is masked to a soft circle that tracks the
  // cursor, lit only while the pointer is over the wordmark's visible top half.
  // The visible top half of the wordmark sits above the footer element, so the
  // pointer is tracked on the document; the rect check below keeps the glow off
  // unless the cursor is actually over the visible wordmark.
  const wm = document.getElementById('ck-foot-wm');
  if (wm && window.matchMedia && !window.matchMedia('(hover: none)').matches) {
    let queued = false;
    let lastX = 0;
    let lastY = 0;
    document.addEventListener('pointermove', (e: PointerEvent) => {
      lastX = e.clientX;
      lastY = e.clientY;
      if (queued) return;
      queued = true;
      requestAnimationFrame(() => {
        queued = false;
        const r = wm.getBoundingClientRect();
        const visibleBottom = r.top + r.height / 2;
        const inside = lastX >= r.left && lastX <= r.right && lastY >= r.top && lastY <= visibleBottom;
        wm.classList.toggle('is-lit', inside);
        if (inside) {
          wm.style.setProperty('--mx', `${lastX - r.left}px`);
          wm.style.setProperty('--my', `${lastY - r.top}px`);
        }
      });
    });
  }
</script>
