---
import { Icon } from 'astro-icon/components';

// Root-relative anchors so the links work from any page (home or a sub-page):
// on the home page they scroll to the section; elsewhere they navigate home first.
const LINKS = [
  { href: '/#rules', label: 'Rules' },
  { href: '/#commands', label: 'Commands' },
  { href: '/#lifecycle', label: 'Lifecycle' },
  { href: '/#gate', label: 'CI gate' },
  { href: '/#trust', label: 'Trust' },
];
---
<header class="ck-nav" id="top">
  <div class="ck-nav__in">
    <a href="/#top" class="ck-logo" aria-label="Charter home">
      <svg width="22" height="22" viewBox="0 0 64 64" fill="currentColor" aria-hidden="true">
        <rect x="3" y="12" width="4" height="40"/><rect x="3" y="12" width="11" height="4"/><rect x="3" y="48" width="11" height="4"/>
        <rect x="57" y="12" width="4" height="40"/><rect x="50" y="12" width="11" height="4"/><rect x="50" y="48" width="11" height="4"/>
        <path d="M41.53,26.5 A11,11 0 1 0 41.53,37.5" fill="none" stroke="currentColor" stroke-width="6"/>
      </svg>
      <span class="ck-wordmark">charter</span>
    </a>
    <nav class="ck-nav__links" aria-label="Main navigation">
      {LINKS.map(l => <a href={l.href}>{l.label}</a>)}
      <a href="https://use-charter.dev/docs" class="ck-nav__gh" rel="noopener noreferrer" target="_blank">
        Docs<Icon name="ph:arrow-up-right" class="ck-nav__ext" />
      </a>
    </nav>
    <div class="ck-nav__cta">
      <button class="ck-theme" id="theme-toggle" aria-label="Toggle theme">
        <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="17" height="17"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.9 4.9l1.4 1.4M17.7 17.7l1.4 1.4M2 12h2M20 12h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"/></svg>
        <svg class="icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="17" height="17"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
      </button>
      <a href="https://github.com/use-charter/charter" class="ck-btn ck-btn--ghost ck-btn--sm" rel="noopener noreferrer" target="_blank" aria-label="GitHub">
        <svg viewBox="0 0 24 24" fill="currentColor" width="15" height="15" aria-hidden="true"><path d="M12 .5C5.7.5.5 5.8.5 12.3c0 5.2 3.4 9.6 8 11.2.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.5-1.4-1.3-1.8-1.3-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1 1.8 2.7 1.3 3.4 1 .1-.8.4-1.3.7-1.6-2.6-.3-5.4-1.3-5.4-5.9 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2a11.4 11.4 0 0 1 6 0C17 4.6 18 4.9 18 4.9c.6 1.7.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.4 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6 4.6-1.6 8-6 8-11.2C23.5 5.8 18.3.5 12 .5z"/></svg>
      </a>
      <a href="https://use-charter.dev/docs/quickstart" rel="noopener noreferrer" class="ck-btn ck-btn--primary ck-btn--sm">Get started</a>
    </div>
  </div>
</header>

<style>
  .icon-moon { display: none; }
  [data-theme="light"] .icon-sun { display: none; }
  [data-theme="light"] .icon-moon { display: block; }
</style>

<script>
  const btn = document.getElementById('theme-toggle');
  btn?.addEventListener('click', () => {
    const next = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    document.documentElement.setAttribute('data-theme', next);
    try { localStorage.setItem('charter-theme', next); } catch(_) {}
  });

  // Active nav link — cleared at top, driven by IntersectionObserver for sections
  const ids = ['rules', 'commands', 'lifecycle', 'gate', 'trust'];
  const links: Record<string, Element | null> = Object.fromEntries(
    ids.map(id => [id, document.querySelector(`.ck-nav__links a[href="/#${id}"]`)])
  );
  const clearAll = () => Object.values(links).forEach(l => l?.classList.remove('is-active'));

  // When user scrolls back near top (hero), remove all active highlights
  window.addEventListener('scroll', () => {
    if (window.scrollY < 120) clearAll();
  }, { passive: true });

  if ('IntersectionObserver' in window) {
    const io = new IntersectionObserver(entries => {
      entries.forEach(e => {
        if (e.isIntersecting) {
          clearAll();
          links[e.target.id]?.classList.add('is-active');
        }
      });
    }, { rootMargin: '-45% 0px -50% 0px', threshold: 0 });
    ids.forEach(id => { const el = document.getElementById(id); if (el) io.observe(el); });
  }
</script>
