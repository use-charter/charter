---
import { Icon } from 'astro-icon/components';

const PILLARS = [
  { icon: 'wifi-slash',    title: 'Completely offline',       body: 'No network calls. No LLM calls. No telemetry. Charter reads your files and nothing leaves the machine.' },
  { icon: 'scales',        title: 'Apache-2.0, free forever', body: 'Open source and permissively licensed. Vendor it, fork it, ship it inside your own tooling.' },
  { icon: 'seal-check',    title: 'SLSA Level 3 signed',      body: 'Every release is supply-chain signed with verifiable provenance. Trust the binary you install.' },
  { icon: 'file-code',     title: 'SARIF 2.1.0 output',       body: 'Standard static-analysis output that drops straight into GitHub Code Scanning and your existing tools.' },
];
const COMMITMENTS = ['No network calls','No LLM calls','No file deletion','No silent mutation','Every finding has a rule ID + fix','Signed releases (SLSA L3)','Public, stable score formula','Cross-vendor','Secrets never printed','CLI free forever'];
---
<section class="ck-section ck-section--alt" id="trust" data-reveal>
  <div class="ck-inner">
    <div class="ck-head">
      <span class="label-caps">The contract</span>
      <h2>It respects your machine and your data</h2>
    </div>
    <div class="ck-pillars">
      {PILLARS.map(p => (
        <div class="ck-pillar">
          <span class="ck-pillar__icon"><Icon name={`ph:${p.icon}`} /></span>
          <h3>{p.title}</h3>
          <p>{p.body}</p>
        </div>
      ))}
    </div>
    <div class="ck-commit">
      {COMMITMENTS.map(c => <span>{c}</span>)}
    </div>
  </div>
</section>
