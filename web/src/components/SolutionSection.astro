---
import Section from './Section.astro';
import { Picture } from 'astro:assets';
import doctorTty from '../assets/screenshots/doctor-tty.webp';
import doctorOverview from '../assets/screenshots/doctor-overview.webp';
import fixDryRun from '../assets/screenshots/fix-dry-run.webp';
---
<Section id="solution" title="How It Works">
  <div class="solution__steps">
    <div class="solution__step reveal">
      <div class="solution__step-header">
        <span class="solution__step-num">01</span>
        <h3 class="solution__step-label">Scan</h3>
      </div>
      <p class="solution__step-desc">Deterministic, offline, no LLM, no network calls.</p>
      <Picture
        src={doctorTty}
        alt="Charter scan output showing all 18 rules checked in under 2 seconds"
        width={864}
        loading="lazy"
        class="solution__screenshot"
      />
    </div>
    <div class="solution__step reveal">
      <div class="solution__step-header">
        <span class="solution__step-num">02</span>
        <h3 class="solution__step-label">Score</h3>
      </div>
      <p class="solution__step-desc">Formula: <code>max(0, 100 − B×20 − H×10 − M×4 − L×1)</code> with four score zones.</p>
      <Picture
        src={doctorOverview}
        alt="Charter score output showing 94/100 ship-ready result in green zone"
        width={864}
        loading="lazy"
        class="solution__screenshot"
      />
    </div>
    <div class="solution__step reveal">
      <div class="solution__step-header">
        <span class="solution__step-num">03</span>
        <h3 class="solution__step-label">Fix</h3>
      </div>
      <p class="solution__step-desc">Diff-first, never auto-fixes secrets, human review always required.</p>
      <Picture
        src={fixDryRun}
        alt="Charter fix dry-run showing unified diff of proposed changes before any write"
        width={864}
        loading="lazy"
        class="solution__screenshot"
      />
    </div>
  </div>
</Section>
