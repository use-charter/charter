---
<Section id="value-props" title="Four Dimensions of Readiness">
  <div class="value-props__grid reveal reveal-group">
    <ValuePropCard
      title="Context"
      description="Can agents see secrets? Outdated AGENTS.md? Missing .env.example?"
      iconPath={icons.context}
    />
    <ValuePropCard
      title="Safety"
      description="Are credentials in agent-visible paths? Policy enforcement?"
      iconPath={icons.safety}
    />
    <ValuePropCard
      title="Operability"
      description="Is there a verify command? Pre-commit integration? CI gating?"
      iconPath={icons.operability}
    />
    <ValuePropCard
      title="Governance"
      description="Can teams waive findings? Are waivers tracked and audited?"
      iconPath={icons.governance}
    />
  </div>
</Section>
