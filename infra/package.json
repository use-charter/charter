{
  "name": "charter-infra",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Cloudflare Workers fronting use-charter.dev (edge router with first-party analytics) and go.use-charter.dev (Go vanity import).",
  "license": "Apache-2.0",
  "author": "Charter",
  "homepage": "https://use-charter.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/use-charter/charter.git",
    "directory": "infra"
  },
  "bugs": "https://github.com/use-charter/charter/issues",
  "engines": {
    "node": ">=24.0.0",
    "bun": ">=1.3.14"
  },
  "packageManager": "bun@1.3.14",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "audit": "bun audit",
    "dev:router": "wrangler dev --config router/wrangler.toml",
    "dev:go-vanity": "wrangler dev --config go-vanity/wrangler.toml",
    "deploy:router": "wrangler deploy --config router/wrangler.toml",
    "deploy:go-vanity": "wrangler deploy --config go-vanity/wrangler.toml",
    "deploy": "bun run deploy:router && bun run deploy:go-vanity"
  },
  "dependencies": {
    "isbot": "5.1.43"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260617.1",
    "@vitest/coverage-v8": "4",
    "typescript": "6.0.3",
    "vitest": "4.1.9",
    "wrangler": "4.102.0"
  },
  "overrides": {
    "esbuild": ">=0.28.1"
  }
}
