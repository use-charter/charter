amends "package://github.com/jdx/hk/releases/download/v1.45.0/hk@1.45.0#/Config.pkl"

fail_fast = true
jobs = 0

hooks {
    ["pre-commit"] {
        steps {
            ["lint"] {
                check = "moon run :lint"
            }
            ["docs"] {
                check = "moon run :docs"
            }
        }
    }

    ["commit-msg"] {
        steps {
            ["conventional-commit"] {
                check = "hk util check-conventional-commit {{commit_msg_file}}"
            }
        }
    }

    ["pre-push"] {
        steps {
            ["test"] {
                check = "moon run :test"
            }
            ["security"] {
                check = "moon run :security"
            }
        }
    }
}
